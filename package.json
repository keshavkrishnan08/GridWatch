{
  "name": "gridwatch-indiana",
  "version": "1.0.0",
  "description": "Interactive atlas mapping every proposed and existing data center in Indiana against the state power grid, sourced from public IURC filings and county records.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/keshavkrishnan08/GridWatch",
  "keywords": [
    "indiana",
    "data-centers",
    "grid",
    "iurc",
    "civic-tech",
    "energy",
    "maplibre"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173 --host",
    "typecheck": "tsc --noEmit",
    "data": "python3 pipeline/build_dataset.py",
    "validate": "python3 -m pipeline.validate_input",
    "region": "python3 -m pipeline.bootstrap",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:py": "python3 -m unittest discover -s pipeline/tests -t .",
    "test:all": "npm run typecheck && npm run test && npm run test:py",
    "freshness": "python3 -m pipeline.check_freshness",
    "refresh": "python3 -m pipeline.refresh_eia",
    "watch": "python3 -m pipeline.watch_sources --check-links",
    "reconcile": "python3 -m pipeline.reconcile"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "maplibre-gl": "^5.24.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keshavkrishnan08/GridWatch.git"
  },
  "bugs": {
    "url": "https://github.com/keshavkrishnan08/GridWatch/issues"
  }
}
